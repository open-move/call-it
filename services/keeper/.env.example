SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_NETWORK=testnet
SUI_KEEPER_REDEEM_KEY=

PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_QUOTE_ASSET=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
CLOCK_OBJECT_ID=0x6

KEEPER_DB_PATH=/app/data/keeper.sqlite
KEEPER_DRY_RUN=true
# Port for the read-only status API (watch + serve commands).
KEEPER_HTTP_PORT=4000
KEEPER_POLL_SECONDS=15
KEEPER_MAX_BATCH_SIZE=10
KEEPER_MAX_CHECKPOINTS_PER_SCAN=25
# Required for a fresh DB. The keeper only manages positions from this
# checkpoint forward (event-sourced horizon).
KEEPER_START_CHECKPOINT=
KEEPER_MIN_PAYOUT=1
# Skip live redemptions when the keeper's gas balance drops below this (MIST).
KEEPER_MIN_SUI_BALANCE=50000000

# Optional keeper reward vault (keeper_rewards package). When KEEPER_REWARD_VAULT_ID
# is set, redemptions route through redeem_with_reward and the keeper is paid the
# vault's fixed reward. Leave unset to use plain predict::redeem_permissionless.
KEEPER_REWARD_PACKAGE_ID=
KEEPER_REWARD_VAULT_ID=
KEEPER_REWARD_COIN_TYPE=0x2::sui::SUI
