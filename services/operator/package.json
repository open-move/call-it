{
  "name": "@callit/operator",
  "private": true,
  "type": "module",
  "scripts": {
    "operator": "bun src/index.ts",
    "deploy": "bun src/deploy.ts",
    "sync-config": "bun src/sync-config.ts",
    "start": "bun src/index.ts --watch --run-all",
    "once": "bun src/index.ts --once --run-all",
    "status": "bun src/index.ts --status --run-all",
    "hedged-plp": "bun src/index.ts --once --run-hedged-plp",
    "range-ladder": "bun src/index.ts --once --run-range-ladder",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "pino": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "typescript": "^6.0.0"
  }
}
