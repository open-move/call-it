# Secrets
SUI_DEPLOYER_KEY=
SUI_KEEPER_KEY=

# Network / runtime
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_NETWORK=testnet
POLL_SECONDS=60
DRY_RUN=false
OPERATOR_FUND_AMOUNT_MIST=2000000000

# On-chain ids (base vault, strategy packages, strategy/manager/keeper-cap ids)
# are read from deployment.<SUI_NETWORK>.json (written by `bun run deploy`).
# Override the path if needed:
# OPERATOR_DEPLOYMENT_PATH=./deployment.testnet.json

# Predict protocol (DeepBook) — not part of our deployment file
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_QUOTE_ASSET=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
CLOCK_OBJECT_ID=0x6
PREDICT_ROUND_UNDERLYING_ASSET=BTC
PREDICT_ROUND_INTERVAL_MS=7200000
PREDICT_ROUND_INTERVAL_TOLERANCE_MS=300000
PREDICT_ROUND_ENTRY_MIN_MS_TO_EXPIRY=4500000
PREDICT_ROUND_ENTRY_MAX_MS_TO_EXPIRY=5400000

# Strategy tuning (on-chain ids come from the deployment file)
HEDGED_PLP_ENABLED=true
HEDGED_PLP_STRIKE_SPOT_BPS=9900
HEDGED_PLP_HEDGE_QUANTITY_BPS_OF_NAV=250

RANGE_LADDER_ENABLED=true
RANGE_RUNG_COUNT=2
RANGE_RUNG_WIDTH_BPS=25
RANGE_QUANTITY_BPS_OF_NAV=250
